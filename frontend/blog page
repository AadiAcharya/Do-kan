      </div>

    </div>

  </section>

  <!-- ================= FOOTER ================= -->

  <footer>

    <div class="footer-container">

      <div class="footer-box">

        <h3>Pasal</h3>

        <p>
          Your favorite destination for fashion & lifestyle.
        </p>

        <div class="social-icons">
          <i class="fa-brands fa-facebook-f"></i>
