        </div>

      </div>

      <!-- CARD -->

      <div class="blog-card">

        <div class="blog-img"></div>

        <div class="blog-content">

          <span class="tag">Accessories</span>

          <h3>Accessories Like A Pro 2026 Edition</h3>

          <p>
